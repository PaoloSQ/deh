</aside>

<div class="help-modal-layer" data-help-modal-layer aria-hidden="true" hidden>
  <div class="help-modal-layer__backdrop" data-help-modal-close></div>

  <section
    class="help-modal help-modal--phone"
    id="help-modal-phone"
    data-help-modal="phone"
    role="dialog"
    aria-modal="true"
    aria-labelledby="help-modal-phone-title"
    aria-describedby="help-modal-phone-desc"
    aria-hidden="true"
    tabindex="-1"
    hidden
  >
    <button
      type="button"
      class="help-modal__close"
      aria-label="Cerrar"
      data-help-modal-close
    >
      <span aria-hidden="true">&times;</span>
    </button>

    <div class="help-phone-modal">
      <figure class="help-phone-modal__visual" aria-hidden="true">
        <img
          src="/img/home/diseno-sin-titulo-edited-2.jpg"
          alt=""
          loading="lazy"
        />
      </figure>

      <div class="help-phone-modal__content">
        <div class="help-phone-modal__copy">
          <h3 id="help-modal-phone-title" class="help-phone-modal__title">
            Queremos ayudarte
          </h3>
          <p id="help-modal-phone-desc" class="help-phone-modal__desc">
            ¿Le gustaría que nos pongamos en contacto con su Administrador de
            Fincas para informarle de todas las ventajas que puede tener al
            contratar alguno de nuestros planes?
          </p>
        </div>

        <div class="help-phone-modal__form-card">
          <h4 class="help-phone-modal__form-title">Formulario de Contacto</h4>
          <form
            class="help-form help-form--phone"
            data-help-form="phone"
            novalidate
          >
          <div class="help-form__grid">
            <label class="help-form__field">
              <span class="help-form__label">Nombre
                <span class="help-form__required">*</span></span>
              <input
                type="text"
                name="firstName"
                autocomplete="given-name"
                aria-label="Nombre"
                required
              />
            </label>

            <label class="help-form__field">
              <span class="help-form__label">Apellido</span>
              <input
                type="text"
                name="lastName"
                autocomplete="family-name"
                aria-label="Apellido"
              />
            </label>

            <label class="help-form__field">
              <span class="help-form__label">Email
                <span class="help-form__required">*</span></span>
              <input
                type="email"
                name="email"
                autocomplete="email"
                aria-label="Email"
                required
              />
            </label>

            <label class="help-form__field">
              <span class="help-form__label">Teléfono
                <span class="help-form__required">*</span></span>
              <input
                type="tel"
                name="phone"
                autocomplete="tel"
                aria-label="Teléfono"
                required
              />
            </label>
          </div>

          <label class="help-form__checkbox">
            <input type="checkbox" name="privacy" required />
            <span>Acepto la
              <a
                href="https://www.dehonline.es/politica-de-privacidad"
                target="_blank"
                rel="noreferrer noopener"
              >política de protección de datos</a>.</span>
          </label>

          <label class="help-form__checkbox">
            <input type="checkbox" name="community" />
            <span>Quiero formar parte de la Comunidad de DEH Online</span>
          </label>

          <label class="help-form__checkbox">
            <input type="checkbox" name="communications" />
            <span>Autorizo el envío de comunicaciones electrónicas informativas
              relativas a las actividades, productos o servicios de DEH</span>
          </label>

            <button class="help-form__submit" type="submit">Enviar</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section
    class="help-modal help-modal--whatsapp"
    id="help-modal-whatsapp"
    data-help-modal="whatsapp"
    role="dialog"
    aria-modal="true"
    aria-labelledby="help-modal-whatsapp-title"
    aria-describedby="help-modal-whatsapp-desc"
    aria-hidden="true"
    tabindex="-1"
    hidden
  >
    <button
      type="button"
      class="help-modal__close"
      aria-label="Cerrar"
      data-help-modal-close
    >
      <span aria-hidden="true">&times;</span>
    </button>

    <div class="help-whatsapp">
      <p class="help-whatsapp__eyebrow">Contacto Whatsapp</p>
      <h3 id="help-modal-whatsapp-title" class="help-whatsapp__title">Bienvenido
        a DEH Online</h3>
      <p id="help-modal-whatsapp-desc" class="help-whatsapp__text">
        Si lo prefieres, podemos ayudarte paso a paso en el proceso de
        contratación desde WhatsApp.
      </p>

      <div class="help-whatsapp__bubble">
        <span class="help-whatsapp__avatar" aria-hidden="true">C</span>
        <div class="help-whatsapp__message">
          <p>
            Hola, soy Celia. Cuéntame qué necesitas y te orientaré hacia la
            solución de DEH Online que mejor encaje contigo.
          </p>
          <span class="help-whatsapp__number">669 887 233</span>
        </div>
      </div>

      <a
        class="help-whatsapp__cta"
        href="https://wa.me/34669887233?text=Hola,%20quiero%20informaci%C3%B3n%20sobre%20DEH%20Online"
        target="_blank"
        rel="noreferrer noopener"
      >Abrir WhatsApp</a>
    </div>
  </section>

  <section
    class="help-modal help-modal--contact"
    id="help-modal-email"
    data-help-modal="email"
    role="dialog"
    aria-modal="true"
    aria-labelledby="help-modal-email-title"
    aria-describedby="help-modal-email-desc"
    aria-hidden="true"
    tabindex="-1"
    hidden
  >
    <button
      type="button"
      class="help-modal__close"
      aria-label="Cerrar"
      data-help-modal-close
    >
      <span aria-hidden="true">&times;</span>
    </button>

    <div class="help-modal__shell">
      <div class="help-modal__intro">
        <p class="help-modal__eyebrow">Formulario de contacto</p>
        <h3
          id="help-modal-email-title"
          class="help-modal__title"
        >Escríbenos</h3>
        <p id="help-modal-email-desc" class="help-modal__text">
          Cuéntanos qué necesitas y prepararemos una respuesta comercial desde
          nuestro correo de atención.
        </p>

        <a
          class="help-modal__quick-link"
          href="mailto:comercial@deh.es"
        >comercial@deh.es</a>
      </div>

      <div class="help-modal__form-wrap">
        <form class="help-form" data-help-form="email" novalidate>
          <div class="help-form__grid">
            <label class="help-form__field help-form__field--full">
              <span class="help-form__label">Nombre y apellidos</span>
              <input type="text" name="name" autocomplete="name" required />
            </label>

            <label class="help-form__field">
              <span class="help-form__label">Empresa</span>
              <input type="text" name="company" autocomplete="organization" />
            </label>

            <label class="help-form__field">
              <span class="help-form__label">Teléfono</span>
              <input type="tel" name="phone" autocomplete="tel" />
            </label>

            <label class="help-form__field help-form__field--full">
              <span class="help-form__label">Correo electrónico</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>

            <label class="help-form__field help-form__field--full">
              <span class="help-form__label">Mensaje</span>
              <textarea
                name="message"
                rows="4"
                placeholder="Describe tu consulta comercial o la demo que quieres ver"
                required
              ></textarea>
            </label>
          </div>

          <label class="help-form__checkbox">
            <input type="checkbox" name="privacy" required />
            <span>Acepto la
              <a
                href="https://www.dehonline.es/politica-de-privacidad"
                target="_blank"
                rel="noreferrer noopener"
              >política de protección de datos</a>.</span>
          </label>

          <button class="help-form__submit" type="submit">Abrir correo preparado</button>
        </form>
      </div>
    </div>
  </section>
</div>