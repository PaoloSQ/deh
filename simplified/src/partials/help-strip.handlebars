        type="button"
        class="help-strip__action help-strip__action--whatsapp"
        data-help-modal-trigger="whatsapp"
        aria-controls="help-modal-whatsapp"
        aria-haspopup="dialog"
        aria-label="Abrir modal de WhatsApp"
        title="WhatsApp"
      >
        <span class="help-strip__action-icon" aria-hidden="true">
