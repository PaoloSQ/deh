        type="button"
        class="help-strip__action help-strip__action--email"
        data-help-modal-trigger="email"
        aria-controls="help-modal-email"
        aria-haspopup="dialog"
        aria-label="Abrir modal de correo"
        title="Correo"
      >
        <span class="help-strip__action-icon" aria-hidden="true">
