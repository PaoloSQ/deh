{
  "name": "deh-simplified",
  "version": "1.0.0",
  "description": "Versión simplificada de dehonline.es",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "watch": "browser-sync start --config bs-config.js",
    "server": "nodemon server.js",
    "format": "npm run format:prettier && npm run format:hbs",
    "format:check": "npm run format:prettier:check",
    "format:prettier": "prettier --write \"**/*.{js,css,json,md}\"",
    "format:prettier:check": "prettier --check \"**/*.{js,css,json,md}\"",
    "format:hbs": "js-beautify --type html --templating handlebars --replace \"src/layouts/*.handlebars\" \"src/partials/*.handlebars\" \"src/pages/index.handlebars\" \"src/pages/404.handlebars\"",
    "import:page": "node scripts/import-page-from-download.js",
    "import:documbox": "node scripts/import-page-from-download.js --page documbox-info",
    "import:certibox": "node scripts/import-page-from-download.js --page certibox",
    "organize:page": "node scripts/organize-page-partials.js",
    "organize:documbox": "node scripts/organize-page-partials.js --page documbox-info",
    "organize:certibox": "node scripts/organize-page-partials.js --page certibox",
    "migrate:page": "node scripts/migrate-page.js",
    "migrate:documbox": "node scripts/migrate-page.js --page documbox-info",
    "migrate:certibox": "node scripts/migrate-page.js --page certibox",
    "clean:page": "node scripts/clean-page.js --write",
    "clean:page:check": "node scripts/clean-page.js --check",
    "clean:documbox": "node scripts/clean-page.js --page documbox-info --write",
    "clean:documbox:dry": "node scripts/clean-page.js --page documbox-info",
    "clean:documbox:check": "node scripts/clean-page.js --page documbox-info --check",
    "clean:certibox": "node scripts/clean-page.js --page certibox --write",
    "clean:certibox:check": "node scripts/clean-page.js --page certibox --check",
    "prune:page": "node scripts/prune-css-safe.js --write",
    "prune:page:check": "node scripts/prune-css-safe.js --check",
    "prune:documbox:dry": "node scripts/prune-css-safe.js --page documbox-info",
    "prune:documbox": "node scripts/prune-css-safe.js --page documbox-info --write",
    "prune:documbox:check": "node scripts/prune-css-safe.js --page documbox-info --check",
    "prune:certibox": "node scripts/prune-css-safe.js --page certibox --write",
    "prune:certibox:check": "node scripts/prune-css-safe.js --page certibox --check",
    "optimize:page": "npm run prune:page && npm run clean:page",
    "optimize:documbox": "npm run prune:documbox && npm run clean:documbox",
    "optimize:documbox:check": "npm run prune:documbox:check && npm run clean:documbox:check",
    "optimize:certibox": "npm run prune:certibox && npm run clean:certibox",
    "optimize:certibox:check": "npm run prune:certibox:check && npm run clean:certibox:check",
    "clean:all:dry": "node scripts/clean-page.js --all",
    "visual": "node scripts/visual.js",
    "visual:capture": "node scripts/visual.js capture",
    "visual:compare": "node scripts/visual.js compare",
    "visual:batch": "node scripts/visual.js batch",
    "visual:report": "node scripts/visual.js report",
    "visual:header": "node scripts/visual.js header",
    "visual:header:all": "node scripts/visual.js header --mode all"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-handlebars": "^7.1.2"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "js-beautify": "^1.15.4",
    "nodemon": "^3.1.14",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.38.0"
  }
}
